# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
LLM_CACHE_SEED=42

# ── System ────────────────────────────────────────────────────────────────────
HUMAN_IN_LOOP=false
MAX_ROUNDS=8
LOG_LEVEL=INFO

# ── Paths ─────────────────────────────────────────────────────────────────────
DB_PATH=credit_risk.db
MODEL_ARTIFACTS_PATH=models/artifacts/

# ── Policy overrides (optional — defaults are in feature_config.py) ───────────
DTI_MAX_PCT=43.0
FICO_MIN=620
LTV_MAX_HARD=0.97
PD_DENY_THRESHOLD=0.35
PD_REFER_THRESHOLD=0.20
